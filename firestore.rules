rules_version = '2';

// ServiceHub / STABILE 2026 — regole unificate (Console → Firestore → Regole → incolla tutto → Pubblica).
//
// Include:
// - users/{userId}     → dati per-utente (solo il proprietario)
// - sharedDial/**      → cruscotto e backup condivisi tra tutti i dispositivi (stesso appId, auth anonima ok)
// - publicDigital      → Digital remoto (lettura pubblica; scrittura solo al proprietario ownerUid)

service cloud.firestore {
  match /databases/{database}/documents {

    // ServiceHub: ogni utente accede solo ai propri dati
    match /artifacts/{appId}/users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ServiceHub: cruscotto + impostazioni + AI + meta + snapshot backup (sync multi-dispositivo)
    match /artifacts/{appId}/sharedDial/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ServiceHub: Digital Report pubblicato (link remoto — lettura aperta, scrittura solo al proprietario)
    match /artifacts/{appId}/publicDigital/{shareId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasAll(['ownerUid', 'updatedAt', 'cardsHTML']);
      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }
  }
}
