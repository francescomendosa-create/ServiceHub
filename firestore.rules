rules_version = '2';

// ServiceHub / STABILE 2026 - Firestore rules (Console: Rules -> paste -> Publish)
// publicDigital: read open; create sets ownerUid; update keeps ownerUid and teamAppId

service cloud.firestore {
  match /databases/{database}/documents {

    match /artifacts/{appId}/users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /artifacts/{appId}/sharedDial/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /artifacts/{appId}/publicDigital/{shareId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid && request.resource.data.keys().hasAll(['ownerUid', 'updatedAt', 'cardsHTML', 'teamAppId']);
      allow update: if request.auth != null && request.resource.data.ownerUid == resource.data.ownerUid && request.resource.data.teamAppId == resource.data.teamAppId && request.resource.data.teamAppId == appId && request.resource.data.keys().hasAll(['ownerUid', 'updatedAt', 'cardsHTML', 'teamAppId']);
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }
  }
}
